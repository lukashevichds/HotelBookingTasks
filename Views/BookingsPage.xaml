<Page x:Class="HotelBookingTasks.Views.BookingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="BookingsPage"
      Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Бронирования"
                       Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="Список бронирований пользователя с быстрым переходом к карточке и автоматическим формированием задач."
                       Foreground="{DynamicResource MutedTextBrush}"/>
        </StackPanel>

        <UniformGrid Grid.Row="2"
                     Columns="3"
                     Margin="0,0,0,16">
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Всего бронирований"
                               Foreground="{DynamicResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding TotalBookings}"
                               FontSize="28"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Активные"
                               Foreground="{DynamicResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding ActiveBookings}"
                               FontSize="28"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Завершенные"
                               Foreground="{DynamicResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding CompletedBookings}"
                               FontSize="28"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="4"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Обновить список"
                            Command="{Binding LoadBookingsCommand}"
                            MinWidth="150"/>
                    <Button Content="Сгенерировать задачи"
                            Command="{Binding GenerateTasksCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="180"/>
                    <Button Content="Открыть карточку"
                            Click="OpenDetailsButton_Click"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="160"/>
                </StackPanel>

                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding Bookings}"
                          SelectedItem="{Binding SelectedBooking, Mode=TwoWay}"
                          CanUserResizeRows="False"
                          SelectionMode="Single"
                          MouseDoubleClick="BookingsDataGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding Id}"
                                            Width="0.7*"/>
                        <DataGridTextColumn Header="Клиент"
                                            Binding="{Binding UserFullName}"
                                            Width="1.5*"/>
                        <DataGridTextColumn Header="Отель"
                                            Binding="{Binding HotelName}"
                                            Width="1.7*"/>
                        <DataGridTextColumn Header="Город"
                                            Binding="{Binding HotelCity}"
                                            Width="1.2*"/>
                        <DataGridTextColumn Header="Заезд"
                                            Binding="{Binding CheckInDate, StringFormat=dd.MM.yyyy HH:mm}"
                                            Width="1.4*"/>
                        <DataGridTextColumn Header="Выезд"
                                            Binding="{Binding CheckOutDate, StringFormat=dd.MM.yyyy HH:mm}"
                                            Width="1.4*"/>
                        <DataGridTextColumn Header="Статус брони"
                                            Binding="{Binding BookingStatus}"
                                            Width="1.2*"/>
                        <DataGridTextColumn Header="Статус оплаты"
                                            Binding="{Binding PaymentStatus}"
                                            Width="1.4*"/>
                        <DataGridTextColumn Header="Стоимость"
                                            Binding="{Binding TotalPrice, StringFormat={}{0:N0} ₽}"
                                            Width="1.1*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>
