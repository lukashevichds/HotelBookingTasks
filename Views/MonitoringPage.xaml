<Page x:Class="HotelBookingTasks.Views.MonitoringPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="MonitoringPage"
      Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Мониторинг системы"
                       Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="Административная панель для контроля подключения, просроченных задач и действий пользователей."
                       Foreground="{DynamicResource MutedTextBrush}"/>
        </StackPanel>

        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Статус БД"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding DatabaseStatus}"/>
                    <TextBlock Text="{Binding DataMode}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="20,0,0,0">
                    <TextBlock Text="Бронирований"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding TotalBookings}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="20,0,0,0">
                    <TextBlock Text="Активных задач"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding ActiveTasks}"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="20,0,0,0">
                    <TextBlock Text="Просрочено"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding OverdueTasks}"/>
                </StackPanel>

                <Button Grid.Column="4"
                        Content="Обновить"
                        Command="{Binding RefreshMonitoringCommand}"
                        MinWidth="130"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="20,0,0,0"/>
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Просроченные задачи"
                               Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <TextBlock Grid.Row="2"
                               Text="{Binding LastUpdated, StringFormat=Последнее обновление: {0:dd.MM.yyyy HH:mm:ss}}"
                               Foreground="{DynamicResource MutedTextBrush}"/>

                    <DataGrid Grid.Row="4"
                              ItemsSource="{Binding OverdueTaskList}"
                              CanUserResizeRows="False"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"
                                                Binding="{Binding Id}"
                                                Width="0.8*"/>
                            <DataGridTextColumn Header="Бронирование"
                                                Binding="{Binding BookingDisplay}"
                                                Width="1.8*"/>
                            <DataGridTextColumn Header="Название"
                                                Binding="{Binding Title}"
                                                Width="1.8*"/>
                            <DataGridTextColumn Header="Срок"
                                                Binding="{Binding Deadline, StringFormat=dd.MM.yyyy HH:mm}"
                                                Width="1.4*"/>
                            <DataGridTextColumn Header="Приоритет"
                                                Binding="{Binding Priority}"
                                                Width="1.1*"/>
                            <DataGridTextColumn Header="Статус"
                                                Binding="{Binding EffectiveStatus}"
                                                Width="1.1*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <Border Grid.Column="2"
                        Background="#F8FAFD"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Журнал действий"
                                   Style="{StaticResource SubtitleTextBlockStyle}"/>

                        <ListBox Grid.Row="2"
                                 ItemsSource="{Binding RecentActions}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
