<Window x:Class="HotelBookingTasks.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Вход в систему"
        Height="420"
        Width="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Border Background="{DynamicResource PrimaryBrush}">
            <Grid Margin="36">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Hotel Booking Tasks"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Margin="0,0,0,12"/>

                    <TextBlock Text="Система управления задачами для клиентов сервиса онлайн-бронирования отелей"
                               FontSize="16"
                               TextWrapping="Wrap"
                               Foreground="White"
                               Opacity="0.95"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="Войдите в приложение, чтобы просматривать бронирования, контролировать статусы задач и отслеживать сроки выполнения."
                               FontSize="14"
                               TextWrapping="Wrap"
                               Foreground="White"
                               Opacity="0.88"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1"
              Margin="40">
            <Border Style="{StaticResource CardBorderStyle}"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Авторизация"
                               Style="{StaticResource TitleTextBlockStyle}"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="Логин"
                               Margin="0,0,0,6"
                               FontWeight="SemiBold"/>

                    <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="Пароль"
                               Margin="0,0,0,6"
                               FontWeight="SemiBold"/>

                    <PasswordBox x:Name="PasswordBox"
                                 Margin="0,0,0,14"
                                 PasswordChanged="PasswordBox_PasswordChanged"/>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{DynamicResource DangerBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,14"/>

                    <Button Content="Войти"
                            Command="{Binding LoginCommand}"
                            MinWidth="120"
                            HorizontalAlignment="Left"/>

                    <TextBlock Text="Тестовые данные: admin / admin"
                               Margin="0,12,0,0"
                               Foreground="{DynamicResource MutedTextBrush}"/>

                    <TextBlock Text="Если PostgreSQL недоступен, приложение автоматически переключится на встроенные демонстрационные данные."
                               Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource MutedTextBrush}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
