<Page x:Class="HotelBookingTasks.Views.BookingDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Title="BookingDetailsPage"
      Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding BookingTitle}"
                       Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="{Binding BookingSubtitle}"
                       Foreground="{DynamicResource MutedTextBrush}"/>
        </StackPanel>

        <Border Grid.Row="1"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="ID бронирования:"
                               FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding SelectedBooking.Id}"/>

                    <TextBlock Grid.Column="2"
                               Text="Статус:"
                               FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="3"
                               Text="{Binding SelectedBooking.BookingStatus}"/>

                    <TextBlock Grid.Row="2"
                               Text="Отель:"
                               FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="2"
                               Grid.Column="1"
                               Text="{Binding SelectedBooking.HotelDisplay}"/>

                    <TextBlock Grid.Row="2"
                               Grid.Column="2"
                               Text="Клиент:"
                               FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="2"
                               Grid.Column="3"
                               Text="{Binding SelectedBooking.UserFullName}"/>

                    <TextBlock Grid.Row="4"
                               Text="Дата заезда:"
                               FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="4"
                               Grid.Column="1"
                               Text="{Binding SelectedBooking.CheckInDate, StringFormat=dd.MM.yyyy HH:mm}"/>

                    <TextBlock Grid.Row="4"
                               Grid.Column="2"
                               Text="Дата выезда:"
                               FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="4"
                               Grid.Column="3"
                               Text="{Binding SelectedBooking.CheckOutDate, StringFormat=dd.MM.yyyy HH:mm}"/>
                </Grid>

                <StackPanel Grid.Row="2"
                            Orientation="Vertical"
                            HorizontalAlignment="Stretch">
                    <TextBlock Text="{Binding SelectedBooking.PaymentStatus, StringFormat=Статус оплаты: {0}}"
                               Margin="0,0,0,4"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding SelectedBooking.TotalPrice, StringFormat=Стоимость: {0:N0} ₽}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding NotesText, StringFormat=Примечание: {0}}"
                               Margin="0,0,0,12"
                               TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Сгенерировать задачи"
                                Command="{Binding GenerateTasksCommand}"
                                MinWidth="180"/>
                        <Button Content="Обновить список"
                                Command="{Binding RefreshTasksCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                MinWidth="150"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Связанные задачи"
                           Style="{StaticResource SubtitleTextBlockStyle}"/>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal">
                    <TextBlock Text="{Binding TotalTasks, StringFormat=Всего задач: {0}}"
                               Foreground="{DynamicResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding OverdueTasks, StringFormat=Просрочено: {0}}"
                               Margin="20,0,0,0"
                               Foreground="{DynamicResource DangerBrush}"/>
                </StackPanel>

                <DataGrid Grid.Row="4"
                          ItemsSource="{Binding Tasks}"
                          SelectedItem="{Binding SelectedTask, Mode=TwoWay}"
                          CanUserResizeRows="False"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Название"
                                            Binding="{Binding Title}"
                                            Width="2*"/>
                        <DataGridTextColumn Header="Описание"
                                            Binding="{Binding Description}"
                                            Width="3*"/>
                        <DataGridTextColumn Header="Срок"
                                            Binding="{Binding Deadline, StringFormat=dd.MM.yyyy HH:mm}"
                                            Width="1.5*"/>
                        <DataGridTextColumn Header="Приоритет"
                                            Binding="{Binding Priority}"
                                            Width="1.2*"/>
                        <DataGridTextColumn Header="Статус"
                                            Binding="{Binding EffectiveStatus}"
                                            Width="1.2*"/>
                        <DataGridTemplateColumn Header="Действие"
                                                Width="1.3*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Выполнить"
                                            Command="{Binding DataContext.MarkTaskCompletedCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"
                                            MinWidth="100"
                                            Height="30"
                                            Margin="4"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Page>
